# Used for local testing only — in AWS these come from SSM Parameter Store
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token

CALENDAR_ID=primary
TIMEZONE=Europe/London
WORK_START=09:00
WORK_END=18:00
LUNCH_START=13:00
LUNCH_END=14:00
TASK_DURATION_MINS=30
BUFFER_MINS=10
MAX_TASKS_PER_DAY=6
